<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/card_background"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Top row: number + type dot + checkmark -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tvCardNumber"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="#001"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"/>

            <View
                android:id="@+id/viewTypeDot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/circle_dot"
                android:layout_marginEnd="4dp"/>

            <ImageView
                android:id="@+id/ivCheckmark"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_check_circle"
                android:visibility="gone"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/ivCardArt"
            android:layout_width="match_parent"
            android:layout_height="128dp"
            android:layout_marginBottom="8dp"
            android:adjustViewBounds="true"
            android:background="@drawable/bg_card_image_placeholder"
            android:contentDescription="@string/card_scan_content_description"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/tvCardName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Card Name"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvCardSet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set Name"
            android:textSize="10sp"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone"
            android:layout_marginBottom="2dp"/>

        <!-- Rarity -->
        <TextView
            android:id="@+id/tvRarity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Common"
            android:textSize="10sp"
            android:textColor="@color/text_secondary"/>

        <!-- Supertype + quantity row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tvSupertype"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pokémon"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:id="@+id/tvQuantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="×1"
                android:textSize="11sp"
                android:textColor="@color/accent_primary"
                android:textStyle="bold"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
