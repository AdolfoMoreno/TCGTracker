<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="315"
                android:centerColor="#F4ECD8"
                android:endColor="#D5C29A"
                android:startColor="#FBF7EF" />
            <stroke
                android:width="1dp"
                android:color="#CCB383" />
        </shape>
    </item>

    <item
        android:bottom="20dp"
        android:left="20dp"
        android:right="20dp"
        android:top="20dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#33FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#55FFFFFF" />
        </shape>
    </item>
</layer-list>
